// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// soort: leesboek, stripboek, encyclopedie
model BookType {
  id            String       @id @default(cuid())
  name          String
  books         Book[]
  defaultSeries BookSeries[] @relation("SeriesDefaultType")
}

// reeks: rode ridder, suske wiske
model BookSeries {
  id                String    @id @default(cuid())
  name              String
  defaultAuthor     String?
  defaultBookType   BookType? @relation("SeriesDefaultType", fields: [defaultBookTypeId], references: [id])
  defaultBookTypeId String?
  books             Book[]
}

// boek: titel, auteur, isbn, kleur/zwartwit
model Book {
  id           String      @id @default(cuid())
  title        String
  author       String?
  isbn         String?
  bookType     BookType    @relation(fields: [bookTypeId], references: [id])
  bookTypeId   String
  bookSeries   BookSeries? @relation(fields: [bookSeriesId], references: [id])
  bookSeriesId String?
  color        Boolean
  imageUrl     String?
  lendings     Lending[]
}

// uitgeleend: aan wie, wanneer, teruggebracht wanneer?
model Lending {
  id         String    @id @default(cuid())
  name       String
  date       DateTime  @default(now())
  returnDate DateTime  @default(now())
  returnedAt DateTime?
  book       Book      @relation(fields: [bookId], references: [id])
  bookId     String
}
