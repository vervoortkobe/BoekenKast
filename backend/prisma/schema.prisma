// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// soort: leesboek, stripboek, encyclopedie
model BookType {
  id    Int    @id @default(autoincrement())
  name  String
  books Book[]
}

// reeks: rode ridder, suske wiske
model BookSeries {
  id    Int    @id @default(autoincrement())
  name  String
  books Book[]
}

// boek: titel, auteur, isbn, kleur/zwartwit
model Book {
  id           Int         @id @default(autoincrement())
  title        String
  author       String
  isbn         String
  bookType     BookType    @relation(fields: [bookTypeId], references: [id])
  bookTypeId   Int
  bookSeries   BookSeries? @relation(fields: [bookSeriesId], references: [id])
  bookSeriesId Int?
  color        Boolean
  lendings     Lending[]
}

// uitgeleend: aan wie, wanneer, teruggebracht wanneer?
model Lending {
  id         Int      @id @default(autoincrement())
  name       String
  date       DateTime @default(now())
  returnDate DateTime @default(now())
  book       Book     @relation(fields: [bookId], references: [id])
  bookId     Int
}
